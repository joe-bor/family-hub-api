<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{correlationId:-no-cid}] %-5level %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Dev profile: show DEBUG for our code, suppress noisy libraries -->
    <springProfile name="dev">
        <logger name="com.familyhub" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>
        <logger name="org.springframework.web" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Prod profile: INFO only, no SQL noise -->
    <springProfile name="prod">
        <logger name="com.familyhub" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Test profile: WARN to keep test output clean -->
    <springProfile name="test">
        <logger name="com.familyhub" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Fallback if no profile matches -->
    <springProfile name="default">
        <logger name="com.familyhub" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
